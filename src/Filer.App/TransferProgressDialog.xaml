<Window x:Class="Filer.App.TransferProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="460"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Background="{DynamicResource Surface.Background}" Title="転送">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource DialogButton}"/>
    </Window.Resources>
    <StackPanel Margin="16">
        <TextBlock x:Name="CurrentText" Foreground="{DynamicResource Fg.Primary}"
                   TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>

        <ProgressBar x:Name="Bar" Height="18" Minimum="0" Maximum="100"
                     Background="{DynamicResource Input.Background}"
                     Foreground="{DynamicResource Accent}"
                     BorderBrush="{DynamicResource Border.Default}" BorderThickness="1"/>

        <Grid Margin="0,8,0,0">
            <TextBlock x:Name="LeftStat" HorizontalAlignment="Left"
                       Foreground="{DynamicResource Fg.Muted}"/>
            <TextBlock x:Name="RightStat" HorizontalAlignment="Right"
                       Foreground="{DynamicResource Fg.Muted}"/>
        </Grid>

        <Button x:Name="CancelButton" Content="キャンセル" Width="100"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="Cancel_Click"/>
    </StackPanel>
</Window>
