<Window x:Class="Filer.App.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="420"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Title="入力">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource DialogButton}"/>
    </Window.Resources>
    <StackPanel Margin="14">
        <TextBlock x:Name="PromptText" Foreground="{DynamicResource Fg.Primary}" Margin="0,0,0,6"/>
        <TextBox x:Name="Input" FontSize="14" Padding="4"
                 Background="{DynamicResource Input.Background}" Foreground="{DynamicResource Fg.Strong}" CaretBrush="{DynamicResource Fg.Strong}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
