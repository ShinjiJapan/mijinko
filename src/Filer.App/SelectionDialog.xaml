<Window x:Class="Filer.App.SelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="520" Height="380"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="選択">
    <DockPanel Margin="10">
        <TextBlock x:Name="PromptText" DockPanel.Dock="Top" Margin="2,0,2,8"
                   Foreground="{DynamicResource Fg.Secondary}" FontSize="13"/>
        <TextBlock x:Name="HelpText" DockPanel.Dock="Bottom" Margin="2,8,2,0" Foreground="{DynamicResource Fg.Subtle}" FontSize="11"
                   Text="↑↓:選択  Enter:決定  Esc:キャンセル"/>
        <ListBox x:Name="List" Background="{DynamicResource Input.Background}" Foreground="{DynamicResource Fg.Primary}"
                 BorderBrush="{DynamicResource Border.Default}" FontFamily="Consolas, MS Gothic" FontSize="13"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseLeftButtonUp="List_MouseLeftButtonUp">
            <ListBox.Resources>
                <!-- 一覧項目: 選択=Selection.Background・ホバー=Row.Hover(テーマ追従)。 -->
                <Style TargetType="ListBoxItem">
                    <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="2,1"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Row.Hover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Selection.Background}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <!-- 編集/削除: アイコンのみのボタン(Segoe MDL2 Assets グリフ)。背景透過・ホバーで強調。 -->
                <Style x:Key="IconButtonStyle" TargetType="Button">
                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Width" Value="24"/>
                    <Setter Property="Height" Value="22"/>
                    <Setter Property="Margin" Value="4,0,0,0"/>
                    <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.Background}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Display}" Padding="2"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <!-- グループ行のサブメニューマーカー -->
                        <TextBlock Grid.Column="1" Text="›" Margin="6,0" FontWeight="Bold"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Fg.Secondary}"
                                   Visibility="{Binding ChevronVisibility}"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding EditButtonsVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button Content="&#xE70F;" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="編集" Click="Edit_Click"/>
                            <Button Content="&#xE74D;" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="削除" Click="Delete_Click"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
