<Window x:Class="Filer.App.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="760" Height="600" MinWidth="640" MinHeight="440"
        ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="設定">
    <Window.Resources>
        <!-- テーマ追従の基本コントロール -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Background" Value="{DynamicResource Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Control}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.BackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Disabled}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.BackgroundDisabled}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource Surface.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{DynamicResource Panel.Background}" BorderBrush="{DynamicResource Border.Default}"
                                BorderThickness="1,1,1,0" CornerRadius="3,3,0,0"
                                Padding="16,7" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.Background}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Background}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{DynamicResource Panel.Background}" BorderBrush="{DynamicResource Border.Default}" BorderThickness="0,0,1,1"
                                Padding="6,5">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="2,3">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Row.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Selection.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Subtle}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- ============ キー割り当て ============ -->
            <TabItem Header="キー割り当て">
                <Grid Margin="10" Background="{DynamicResource App.Background}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 検索 -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="検索:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource Fg.Secondary}"/>
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"
                                 ToolTip="操作名・キーで絞り込み"/>
                    </DockPanel>

                    <!-- 一覧(カテゴリごとにグループ表示) -->
                    <ListView x:Name="BindingList" Grid.Row="1"
                              Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource Border.Default}" Foreground="{DynamicResource Fg.Primary}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              MouseDoubleClick="BindingList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="操作" Width="330">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="キー" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding GesturesText}" Foreground="{DynamicResource Accent.Text}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="変更" Width="46">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CustomMark}" Foreground="{DynamicResource CustomMark.Foreground}"
                                                       HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource Accent.Bright}"
                                                   Margin="4,10,0,3"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                    </ListView>

                    <!-- キー入力キャプチャ中のバー -->
                    <Border x:Name="CaptureBar" Grid.Row="2" Background="{DynamicResource Capture.Background}" BorderBrush="{DynamicResource Capture.Border}"
                            BorderThickness="1" CornerRadius="3" Padding="10,7" Margin="0,8,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="CaptureText" Foreground="{DynamicResource Fg.Primary}" FontSize="13"/>
                    </Border>

                    <!-- 操作ボタン -->
                    <DockPanel Grid.Row="3" Margin="0,8,0,0">
                        <Button x:Name="ResetAllButton" DockPanel.Dock="Right" Content="すべて既定に戻す"
                                Click="ResetAll_Click"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ChangeButton" Content="キーを変更..." Click="Change_Click"
                                    ToolTip="選択した操作のキーを置き換える(ダブルクリック/Enter でも可)"/>
                            <Button x:Name="AddButton" Content="キーを追加..." Click="Add_Click" Margin="8,0,0,0"
                                    ToolTip="今のキーを残したまま別のキーを追加する"/>
                            <Button x:Name="ClearButton" Content="割り当て解除" Click="Clear_Click" Margin="8,0,0,0"/>
                            <Button x:Name="ResetButton" Content="既定に戻す" Click="Reset_Click" Margin="8,0,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ============ 外部ツール ============ -->
            <TabItem Header="外部ツール">
                <Grid Margin="10" Background="{DynamicResource App.Background}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource HintText}" Margin="2,4,2,8" FontSize="12"
                               Text="外部ツールを自由に追加・削除できます。実行ファイル or ストアアプリ(インストール済みアプリ)を選び、引数はマクロで指定します。キーは各ツールの編集画面で割り当てます。"/>

                    <ListView x:Name="ToolList" Grid.Row="1"
                              Background="{DynamicResource App.Background}" BorderBrush="{DynamicResource Border.Default}" Foreground="{DynamicResource Fg.Primary}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              MouseDoubleClick="ToolList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ラベル" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="種類" Width="84">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding KindText}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="対象" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource Fg.Muted}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="キー" Width="92">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding KeyText}" Foreground="{DynamicResource Accent.Text}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <DockPanel Grid.Row="2" Margin="0,8,0,0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="ToolUpButton" Content="↑" Width="34" Click="ToolUp_Click"/>
                            <Button x:Name="ToolDownButton" Content="↓" Width="34" Click="ToolDown_Click" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="追加..." Click="ToolAdd_Click"/>
                            <Button x:Name="ToolEditButton" Content="編集..." Click="ToolEdit_Click" Margin="8,0,0,0"/>
                            <Button x:Name="ToolDuplicateButton" Content="複製" Click="ToolDuplicate_Click" Margin="8,0,0,0"/>
                            <Button x:Name="ToolDeleteButton" Content="削除" Click="ToolDelete_Click" Margin="8,0,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ============ 外観 ============ -->
            <TabItem Header="外観">
                <StackPanel Margin="16" Background="{DynamicResource App.Background}">
                    <TextBlock Text="テーマ" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Fg.Secondary}" Margin="0,4,0,10"/>
                    <RadioButton x:Name="ThemeDark" GroupName="Theme" Content="ダーク" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeLight" GroupName="Theme" Content="ライト" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeBeige" GroupName="Theme" Content="ベージュ(暖色アースカラー)" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeGreen" GroupName="Theme" Content="グリーン(アースグリーン)" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeNord" GroupName="Theme" Content="Nord(寒色ダーク)" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeSolarized" GroupName="Theme" Content="Solarized Light(暖色ライト)" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeDracula" GroupName="Theme" Content="Dracula(紫系ダーク)" Checked="Theme_Checked"/>
                    <RadioButton x:Name="ThemeSystem" GroupName="Theme" Content="Windows に合わせる" Checked="Theme_Checked"/>
                    <TextBlock Style="{StaticResource HintText}" Margin="0,12,0,0" FontSize="12"
                               Text="テーマはラジオを選んだ瞬間に全ウィンドウ(Markdown プレビュー含む)へプレビュー反映されます。OK で確定、キャンセルで元に戻ります。「Windows に合わせる」は起動時と設定変更時に OS のライト/ダーク設定を読み取ります。"/>

                    <TextBlock Text="パフォーマンス" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Fg.Secondary}" Margin="0,20,0,10"/>
                    <CheckBox x:Name="LightweightUiaCheck" Foreground="{DynamicResource Fg.Primary}"
                              Content="ファイル一覧の行を UI Automation に公開しない(大量フォルダーの移動を高速化)"/>
                    <TextBlock Style="{StaticResource HintText}" Margin="24,6,0,0" FontSize="12" TextWrapping="Wrap"
                               Text="UIA クライアント(スクリーンリーダーや画面を読み取る常駐ツール)が動いている環境では、フォルダー移動のたびに全行分の UIA 処理が走り数百 ms 遅くなることがあります。ON にするとこれを回避できますが、スクリーンリーダーでの行の読み上げや、UIA を使った自動操作ツールから一覧の行が見えなくなります。OK で即時反映(再起動不要)。"/>
                </StackPanel>
            </TabItem>

            <!-- ============ 確認ダイアログ ============ -->
            <TabItem Header="確認">
                <StackPanel Margin="16" Background="{DynamicResource App.Background}">
                    <TextBlock Text="操作前の確認ダイアログ" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Fg.Secondary}" Margin="0,4,0,10"/>
                    <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,12" FontSize="12"
                               Text="チェックを外した操作は、確認ダイアログを出さず即座に実行します。"/>

                    <CheckBox x:Name="ConfirmMoveCheck" Foreground="{DynamicResource Fg.Primary}"
                              Content="移動(M)の前に確認する"/>
                    <CheckBox x:Name="ConfirmRecycleCheck" Foreground="{DynamicResource Fg.Primary}" Margin="0,10,0,0"
                              Content="ごみ箱へ送る(D / Delete)の前に確認する"/>
                    <CheckBox x:Name="ConfirmPermanentDeleteCheck" Foreground="{DynamicResource Fg.Primary}" Margin="0,10,0,0"
                              Content="完全削除(Shift+D)の前に確認する"/>
                    <TextBlock Style="{StaticResource HintText}" Margin="24,4,0,0" FontSize="12"
                               Text="完全削除はごみ箱を経由せず元に戻せません。確認を外す場合はご注意ください。"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- OK / キャンセル -->
        <DockPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left" Style="{StaticResource HintText}" VerticalAlignment="Center"
                       Text="設定は %APPDATA%\Filer\settings.json に保存され、OK で即時反映されます。"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="92" Click="Ok_Click" Margin="0,0,8,0"/>
                <Button Content="キャンセル" Width="92" IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
