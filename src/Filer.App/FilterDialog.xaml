<Window x:Class="Filer.App.FilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="フィルター表示">
    <Window.Resources>
        <!-- テーマ追従の基本コントロール(他ダイアログと同じ見た目) -->
        <Style TargetType="Button" BasedOn="{StaticResource DialogButton}"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="14" Width="352">
        <TextBox x:Name="Pattern" FontSize="14" TextChanged="Pattern_TextChanged"/>
        <DockPanel Margin="2,8,2,0">
            <TextBlock x:Name="CountText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                       Foreground="{DynamicResource Fg.Subtle}" FontSize="11"/>
            <TextBlock Foreground="{DynamicResource Fg.Subtle}" FontSize="11"
                       Text="例: *.jpg / 部分一致はそのまま入力"/>
        </DockPanel>
        <DockPanel Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="決定" Width="92" Focusable="False" IsDefault="True" Click="Apply_Click" Margin="0,0,8,0"/>
                <Button Content="キャンセル" Width="92" Focusable="False" IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
