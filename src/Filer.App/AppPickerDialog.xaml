<Window x:Class="Filer.App.AppPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="560" Height="520" MinWidth="420" MinHeight="320"
        ResizeMode="CanResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="アプリを選択">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Background" Value="{DynamicResource Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Control}"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <!-- 列ヘッダー(アプリ名/AUMID): テーマ追従。 -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{DynamicResource Panel.Background}" BorderBrush="{DynamicResource Border.Default}" BorderThickness="0,0,1,1"
                                Padding="6,5">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 一覧項目: 選択=Selection.Background・ホバー=Row.Hover(テーマ追従)。 -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="2,3">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Row.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Selection.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="検索:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource Fg.Secondary}"/>
            <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
        </DockPanel>

        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="2,8,2,0"
                   Foreground="{DynamicResource Fg.Subtle}" FontSize="11" Text="読み込み中..."/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="90" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Width="90" IsCancel="True"/>
        </StackPanel>

        <ListView x:Name="AppList" Background="{DynamicResource Input.Background}" BorderBrush="{DynamicResource Border.Default}" Foreground="{DynamicResource Fg.Primary}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="AppList_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="アプリ名" Width="300" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="AUMID" Width="210" DisplayMemberBinding="{Binding Aumid}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
