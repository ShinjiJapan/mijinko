<Window x:Class="Filer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Filer.App"
        xmlns:vm="clr-namespace:Filer.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding StatusText}" Height="600" Width="1000"
        Icon="Assets/appicon.ico"
        Background="{DynamicResource App.Background}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- 一覧の行スタイル: マーク行・親・ディレクトリ・ファイルで色分け。
             選択ハイライト背景は使わず、アクティブペインの選択行のみ下線で示す。 -->
        <Style x:Key="EntryRowStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <!-- フォーカス枠は出さない(選択は下線で示す)。移動後に元の行へ枠が残るのを防ぐ。 -->
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <!-- 下線スペース(1px)は常に確保し色だけ切替。選択行だけ高さが変わるのを防ぐ。 -->
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- アクティブペイン(論理的なアクティブ状態)の選択行のみ下線を強調。
                                 OS フォーカスではなく IsActive で判定するため、アプリ非アクティブ時も下線は残る。 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.IsActive, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Entry.Underline}"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Entry.Directory}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMarked}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Marked.Background}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Marked.Foreground}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 名前セル: Git 状態バッジ(M/A/?/!)+名前。バッジ枠は固定幅で確保し、状態なしは
             透明背景+空文字で見えない(名前の開始位置は全行で揃う)。バッジ色はテーマ非依存の固定色。
             名前 TextBlock の文字色は ListViewItem からの継承(ディレクトリ色・マーク色)に従う。 -->
        <DataTemplate x:Key="NameCellTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding DataContext.GitBadgeColumnWidth, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{Binding GitBadgeBrush}" CornerRadius="3"
                        Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.HasGitRepository, RelativeSource={RelativeSource AncestorType=ListView}}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding GitBadge}" Foreground="White"
                               FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"
                           Margin="{Binding DataContext.GitNameMargin, RelativeSource={RelativeSource AncestorType=ListView}}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>

        <!-- パンくず右端の Git ブランチ表示(例 "main ↑1")。リポジトリ外(空文字)は場所ごと畳む -->
        <Style x:Key="GitBranchTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Git.Branch}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- パンくず横のフィルター表示(例 "絞り込み: *.jpg")。フィルターなし(空文字)は場所ごと畳む -->
        <Style x:Key="FilterTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- パンくず(階層パス)の各区切りボタン: 背景透過・ホバーで強調 -->
        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.Background}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- パンくずバー共通テンプレート(横並び・区切りに ›) -->
        <DataTemplate x:Key="BreadcrumbItemTemplate">
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding Name}" Click="Breadcrumb_Click"
                        Style="{StaticResource BreadcrumbButtonStyle}"
                        Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                <TextBlock Text="›" Foreground="{DynamicResource Fg.Subtle}" VerticalAlignment="Center" Margin="1,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- タブ1枚分(ListBoxItem): 見出し+×。選択タブは一覧と同色で繋がって見せる -->
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Muted}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{DynamicResource Panel.Background}" CornerRadius="4,4,0,0"
                                Padding="8,3" SnapsToDevicePixels="True"
                                MaxWidth="180">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Content="×" Click="CloseTab_Click" Margin="6,0,0,0"
                                        Padding="3,0" FontSize="11" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource Fg.Subtle}" VerticalAlignment="Center"
                                        FocusVisualStyle="{x:Null}"
                                        ToolTip="タブを閉じる (Ctrl+W)"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface.Background}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.Background}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- タブ列(横並びの ListBox)。背景透過・枠なし -->
        <Style x:Key="TabStripStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource TabItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 新規タブ(+)ボタン -->
        <Style x:Key="AddTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Muted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.Background}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ペイン共通の ListView テンプレート -->
        <Style x:Key="PaneListStyle" TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource Surface.Background}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="FontFamily" Value="Consolas, MS Gothic"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource EntryRowStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        </Style>

        <!-- 一覧の列ヘッダー(名前/拡張子/サイズ/更新日時)。テーマ追従・ホバー強調・クリックでソート。
             列ヘッダーの Content は文字列(ソート時 ▲▼ 付き)なので ContentPresenter で表示する。 -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="Bd" Background="{DynamicResource Panel.Background}"
                                BorderBrush="{DynamicResource Border.Default}" BorderThickness="0,0,1,1"
                                Padding="8,5" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.Background}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.BackgroundHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ペイン外枠: アクティブ側をアクセント色で強調(テーマ追従)。 -->
        <Style x:Key="LeftPaneBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Left.IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RightPaneBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Right.IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Col0" Width="*"/>
                <ColumnDefinition x:Name="ColSplit" Width="4"/>
                <ColumnDefinition x:Name="Col2" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左ペイン -->
            <Border x:Name="LeftPane" Grid.Column="0" Style="{StaticResource LeftPaneBorderStyle}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource App.Background}" Padding="4,2,4,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="+" Style="{StaticResource AddTabButtonStyle}"
                                    Click="AddTab_Click" Tag="Left" ToolTip="新しいタブ (Ctrl+T)"/>
                            <ListBox ItemsSource="{Binding Left.Tabs}" Tag="Left"
                                     SelectedIndex="{Binding Left.ActiveTabIndex, Mode=TwoWay}"
                                     Style="{StaticResource TabStripStyle}"
                                     PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"/>
                        </DockPanel>
                    </Border>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource PanelAlt.Background}" Padding="4,2">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding Left.MarkSummaryText}"
                                       Foreground="{DynamicResource Fg.Subtle}" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,2,0"/>
                            <WrapPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding Left.Breadcrumb}" Tag="Left"
                                              ItemTemplate="{StaticResource BreadcrumbItemTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock Text="{Binding Left.GitBranchText}"
                                           Style="{StaticResource GitBranchTextStyle}"/>
                                <TextBlock Text="{Binding Left.FilterText}"
                                           Style="{StaticResource FilterTextStyle}"/>
                            </WrapPanel>
                        </DockPanel>
                    </Border>
                    <local:PaneListView x:Name="LeftList" Style="{StaticResource PaneListStyle}"
                              DataContext="{Binding Left}"
                              ItemsSource="{Binding Entries}"
                              SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                              GotKeyboardFocus="Pane_GotKeyboardFocus" Tag="Left"
                              GridViewColumnHeader.Click="ColumnHeader_Click">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="Auto">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding IconImage}" Width="16" Height="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="名前" Width="219" CellTemplate="{StaticResource NameCellTemplate}"/>
                                <GridViewColumn Header="拡張子" Width="Auto" DisplayMemberBinding="{Binding DisplayExtension}"/>
                                <GridViewColumn Header="サイズ" Width="Auto" DisplayMemberBinding="{Binding DisplaySize}"/>
                                <GridViewColumn Header="更新日時" Width="Auto" DisplayMemberBinding="{Binding DisplayDate}"/>
                            </GridView>
                        </ListView.View>
                    </local:PaneListView>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="PaneSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="{DynamicResource Border.Default}"/>

            <!-- 右ペイン -->
            <Border x:Name="RightPane" Grid.Column="2" Style="{StaticResource RightPaneBorderStyle}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource App.Background}" Padding="4,2,4,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="+" Style="{StaticResource AddTabButtonStyle}"
                                    Click="AddTab_Click" Tag="Right" ToolTip="新しいタブ (Ctrl+T)"/>
                            <ListBox ItemsSource="{Binding Right.Tabs}" Tag="Right"
                                     SelectedIndex="{Binding Right.ActiveTabIndex, Mode=TwoWay}"
                                     Style="{StaticResource TabStripStyle}"
                                     PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"/>
                        </DockPanel>
                    </Border>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource PanelAlt.Background}" Padding="4,2">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding Right.MarkSummaryText}"
                                       Foreground="{DynamicResource Fg.Subtle}" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,2,0"/>
                            <!-- パンくず(フォルダパス)+その直後に Git ブランチ "(branch)" を横並びで表示 -->
                            <WrapPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding Right.Breadcrumb}" Tag="Right"
                                              ItemTemplate="{StaticResource BreadcrumbItemTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock Text="{Binding Right.GitBranchText}"
                                           Style="{StaticResource GitBranchTextStyle}"/>
                                <TextBlock Text="{Binding Right.FilterText}"
                                           Style="{StaticResource FilterTextStyle}"/>
                            </WrapPanel>
                        </DockPanel>
                    </Border>
                    <local:PaneListView x:Name="RightList" Style="{StaticResource PaneListStyle}"
                              DataContext="{Binding Right}"
                              ItemsSource="{Binding Entries}"
                              SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                              GotKeyboardFocus="Pane_GotKeyboardFocus" Tag="Right"
                              GridViewColumnHeader.Click="ColumnHeader_Click">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="Auto">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding IconImage}" Width="16" Height="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="名前" Width="219" CellTemplate="{StaticResource NameCellTemplate}"/>
                                <GridViewColumn Header="拡張子" Width="Auto" DisplayMemberBinding="{Binding DisplayExtension}"/>
                                <GridViewColumn Header="サイズ" Width="Auto" DisplayMemberBinding="{Binding DisplaySize}"/>
                                <GridViewColumn Header="更新日時" Width="Auto" DisplayMemberBinding="{Binding DisplayDate}"/>
                            </GridView>
                        </ListView.View>
                    </local:PaneListView>
                </DockPanel>
            </Border>

            <!-- 組み込みターミナルのオーバーレイ。1画面時は片側の列、全画面時は全列(ColumnSpan)を覆う。
                 WebView2 を再ペアレントせず列スパンだけ変えるため、表示切替で再初期化されない。 -->
            <Border x:Name="TerminalHost" Grid.Column="2" Margin="2" Background="{DynamicResource App.Background}"
                    Visibility="Collapsed" Panel.ZIndex="5"/>
        </Grid>

        <!-- ステータス/ヘルプバー -->
        <Border Grid.Row="1" Background="{DynamicResource Accent}" Padding="8,4">
            <TextBlock x:Name="KeyHelpText" Foreground="{DynamicResource Fg.OnAccent}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
