<Window x:Class="Filer.App.FileSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="640" Height="520" MinWidth="520" MinHeight="360"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="ファイル検索">
    <Window.Resources>
        <!-- テーマ追従の基本コントロール(IncrementalSearchDialog と同じ見た目) -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Background" Value="{DynamicResource Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Control}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.BackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Disabled}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Control.BackgroundDisabled}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 条件入力(左)+ ボタン列(右) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <Label Content="検索ファイル名(_F)" Target="{Binding ElementName=Query}"/>
                <TextBox x:Name="Query" FontSize="14"/>
                <CheckBox x:Name="RegexCheck" Content="正規表現(_E)" Margin="0,6,0,0"/>
                <Label Content="基準ディレクトリ(_B)" Target="{Binding ElementName=BaseDir}" Margin="0,10,0,0"/>
                <TextBox x:Name="BaseDir" FontSize="13"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <CheckBox x:Name="FileCheck" Content="ファイル(_N)" IsChecked="True"/>
                    <CheckBox x:Name="DirCheck" Content="ディレクトリ(_D)" Margin="14,0,0,0"/>
                    <CheckBox x:Name="ArchiveCheck" Content="圧縮ファイル内も検索(_A)" Margin="14,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <Button x:Name="SearchButton" Content="検索開始(_S)" Width="124" IsDefault="True" Click="Search_Click"/>
                <Button x:Name="TransferButton" Content="転送して閉じる(_T)" Width="124" Margin="0,6,0,0"
                        IsEnabled="False" Click="Transfer_Click"/>
                <Button Content="閉じる(_C)" Width="124" Margin="0,6,0,0" IsCancel="True"/>
                <Button x:Name="JumpButton" Content="ジャンプ(_J)" Width="124" Margin="0,6,0,0"
                        IsEnabled="False" Click="Jump_Click"/>
                <!-- 非管理者起動時のみ表示。MFT 直読みの高速検索を昇格ヘルパー経由で行う。 -->
                <Button x:Name="FastSearchButton" Width="124" Margin="0,14,0,0"
                        Visibility="Collapsed" Click="FastSearch_Click"
                        ToolTip="管理者権限の常駐ヘルパーで MFT 索引を使い高速検索します(初回のみ UAC 承認)">
                    <TextBlock Text="高速検索(管理者権限が必要)(_G)" TextWrapping="Wrap" TextAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="1" Margin="2,12,2,4">
            <TextBlock Text="検索結果" Foreground="{DynamicResource Fg.Secondary}"/>
            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Marked.Foreground}"
                       Margin="16,0,0,0" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="CountText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                       Foreground="{DynamicResource Fg.Primary}"/>
            <!-- 使用エンジン(MFT索引/通常走査)と MFT が使えなかった理由を明示する -->
            <TextBlock x:Name="EngineText" HorizontalAlignment="Right" Margin="0,0,16,0"
                       Foreground="{DynamicResource Fg.Subtle}" TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <ListBox x:Name="ResultsList" Grid.Row="2"
                 Background="{DynamicResource Input.Background}" Foreground="{DynamicResource Fg.Primary}"
                 BorderBrush="{DynamicResource Border.Default}" FontFamily="Consolas, MS Gothic" FontSize="13"
                 HorizontalContentAlignment="Stretch"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 SelectionChanged="ResultsList_SelectionChanged"
                 MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListBox.Resources>
                <!-- 一覧項目: 選択=Selection.Background・ホバー=Row.Hover(テーマ追従)。 -->
                <Style TargetType="ListBoxItem">
                    <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="4,1"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Row.Hover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Selection.Background}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
