<Window x:Class="Filer.App.IncrementalSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="インクリメンタルサーチ">
    <Window.Resources>
        <!-- テーマ追従の基本コントロール(SettingsDialog と同じ見た目) -->
        <Style TargetType="Button" BasedOn="{StaticResource DialogButton}"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="14" Width="352">
        <TextBox x:Name="Query" FontSize="14" TextChanged="Query_TextChanged"/>
        <DockPanel Margin="0,8,0,0">
            <CheckBox x:Name="PrefixCheck" Content="先頭から検索" IsChecked="True" Focusable="False"
                      Checked="Prefix_Changed" Unchecked="Prefix_Changed"/>
            <TextBlock x:Name="NoMatchText" Text="一致なし" Visibility="Hidden"
                       Foreground="{DynamicResource Marked.Foreground}" HorizontalAlignment="Right"/>
        </DockPanel>
        <TextBlock Foreground="{DynamicResource Fg.Subtle}" FontSize="11" Margin="2,10,2,0" TextWrapping="Wrap"
                   Text="↑↓:前/次の一致へ  Enter:決定  Esc:キャンセル(元の位置へ)"/>
        <DockPanel Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="上方検索" Focusable="False" Click="SearchUp_Click"/>
                <Button Content="下方検索" Focusable="False" Click="SearchDown_Click" Margin="8,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="閉じる" Width="92" Focusable="False" IsDefault="True" Click="Close_Click" Margin="0,0,8,0"/>
                <Button Content="キャンセル" Width="92" Focusable="False" IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
