<Window x:Class="Filer.App.OverwriteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}"
        Title="同名のファイル">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource DialogButton}"/>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Margin" Value="2,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="Padding" Value="3,2"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="14" Width="430">
        <TextBlock x:Name="PathText" FontWeight="SemiBold" TextWrapping="Wrap" Margin="2,0,2,6"/>
        <TextBlock Text="同名のファイルが存在します。" Foreground="{DynamicResource Fg.Secondary}" Margin="2,0,2,8"/>

        <GroupBox Header="転送元">
            <TextBlock x:Name="SrcInfo" Margin="8,4" />
        </GroupBox>
        <TextBlock Text="↓" HorizontalAlignment="Center" FontSize="14" Margin="0,2"/>
        <GroupBox Header="転送先">
            <TextBlock x:Name="DestInfo" Margin="8,4" />
        </GroupBox>

        <StackPanel Margin="2,12,2,0">
            <RadioButton x:Name="NewerRadio" Content="新しいものだけ転送(_N)"/>
            <RadioButton x:Name="OverwriteRadio" Content="上書き(_O)"/>
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="RenameRadio" Grid.Column="0" Content="名前を変更して転送(_R)" Margin="2,0"/>
                <TextBox x:Name="RenameBox" Grid.Column="1" Margin="6,0,2,0"
                         GotKeyboardFocus="RenameBox_GotKeyboardFocus"/>
            </Grid>
            <RadioButton x:Name="SkipRadio" Content="転送しない(_I)"/>
        </StackPanel>

        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="ApplyAllCheck" Grid.Column="0" Content="すべてのファイルに適用(SHIFT)"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="キャンセル" Width="90" IsCancel="True" Margin="0,0,8,0"/>
                <Button Content="OK" Width="90" IsDefault="True" Click="Ok_Click"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>
