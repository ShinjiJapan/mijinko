<Window x:Class="Filer.App.CommandPaletteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="620" Height="460"
        ResizeMode="NoResize" ShowInTaskbar="False" WindowStyle="ToolWindow"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}"
        Title="コマンドパレット">
    <DockPanel Margin="10">
        <TextBox x:Name="Query" DockPanel.Dock="Top" Margin="0,0,0,8" Padding="6,5" FontSize="14"
                 Background="{DynamicResource Input.Background}" Foreground="{DynamicResource Fg.Primary}"
                 BorderBrush="{DynamicResource Border.Default}"
                 CaretBrush="{DynamicResource Fg.Primary}"
                 TextChanged="Query_TextChanged"/>
        <TextBlock x:Name="HelpText" DockPanel.Dock="Bottom" Margin="2,8,2,0"
                   Foreground="{DynamicResource Fg.Subtle}" FontSize="11"
                   Text="↑↓:選択  Enter:実行  Esc:閉じる"/>
        <ListBox x:Name="List" Background="{DynamicResource Input.Background}" Foreground="{DynamicResource Fg.Primary}"
                 BorderBrush="{DynamicResource Border.Default}" FontSize="13"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseLeftButtonUp="List_MouseLeftButtonUp">
            <ListBox.Resources>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="2,2"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Row.Hover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Selection.Background}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Category}" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{DynamicResource Fg.Subtle}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Margin="8,0,2,0" Padding="6,1" CornerRadius="3"
                                Background="{DynamicResource Control.Background}"
                                BorderBrush="{DynamicResource Border.Control}" BorderThickness="1"
                                Visibility="{Binding GestureVisibility}">
                            <TextBlock Text="{Binding GestureText}" FontFamily="Consolas, MS Gothic"
                                       FontSize="11" Foreground="{DynamicResource Fg.Secondary}"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
