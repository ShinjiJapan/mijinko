<Window x:Class="Filer.App.ToolEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="600" SizeToContent="Height" MinWidth="520"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}" Title="外部ツールの編集">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Background" Value="{DynamicResource Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Control}"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Fg.Strong}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Subtle}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="ラベル(表示名)" Margin="0,0,0,4"/>
        <TextBox x:Name="LabelBox" Margin="0,0,0,12"/>

        <TextBlock Text="種類" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="KindExe" Content="実行ファイル" GroupName="Kind"
                         Checked="Kind_Changed" IsChecked="True"/>
            <RadioButton x:Name="KindStore" Content="ストアアプリ(インストール済みアプリ)" GroupName="Kind"
                         Checked="Kind_Changed"/>
        </StackPanel>

        <TextBlock x:Name="TargetLabel" Text="実行ファイルのパス" Margin="0,0,0,4"/>
        <DockPanel Margin="0,0,0,4">
            <Button x:Name="BrowseButton" DockPanel.Dock="Right" Content="参照..." Margin="8,0,0,0"
                    Click="Browse_Click"/>
            <Button x:Name="PickAppButton" DockPanel.Dock="Right" Content="アプリを選択..." Margin="8,0,0,0"
                    Click="PickApp_Click" Visibility="Collapsed"/>
            <TextBox x:Name="TargetBox"/>
        </DockPanel>
        <TextBlock x:Name="TargetHint" Style="{StaticResource Hint}" Margin="0,0,0,12"
                   Text="フルパス、または PATH 上の名前(例: Code.exe)。Code.exe / wt.exe / git-bash.exe は既知の場所も自動探索します。"/>

        <DockPanel Margin="0,0,0,4">
            <Button DockPanel.Dock="Right" Content="マクロ一覧 ?" Margin="8,0,0,0" Click="MacroHelp_Click"/>
            <TextBlock Text="引数(マクロ使用可)" VerticalAlignment="Center"/>
        </DockPanel>
        <TextBox x:Name="ArgsBox" Margin="0,0,0,4"
                 FontFamily="Consolas, MS Gothic"/>
        <TextBlock x:Name="ArgsHint" Style="{StaticResource Hint}" Margin="0,0,0,12"
                   Text="例: -d &quot;$P&quot;(自窓フォルダー)/ $MF(マーク or カーソルのフルパス)。「マクロ一覧 ?」で全マクロを表示。"/>

        <TextBlock Text="キー割り当て" Margin="0,0,0,4"/>
        <DockPanel Margin="0,0,0,4">
            <Button x:Name="CaptureButton" DockPanel.Dock="Right" Content="キーを設定..." Margin="8,0,0,0"
                    Click="Capture_Click"/>
            <Button x:Name="ClearKeyButton" DockPanel.Dock="Right" Content="クリア" Margin="8,0,0,0"
                    Click="ClearKey_Click"/>
            <Border Background="{DynamicResource Input.Background}" BorderBrush="{DynamicResource Border.Default}" BorderThickness="1" CornerRadius="2" Padding="6,4">
                <TextBlock x:Name="KeyText" Foreground="{DynamicResource Accent.Text}" Text="(未割り当て)"/>
            </Border>
        </DockPanel>

        <Border x:Name="CaptureBar" Background="{DynamicResource Capture.Background}" BorderBrush="{DynamicResource Capture.Border}" BorderThickness="1"
                CornerRadius="3" Padding="10,7" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock x:Name="CaptureText" Foreground="{DynamicResource Fg.Primary}" FontSize="13"
                       Text="割り当てるキーを押してください(Esc: 中止)"/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="92" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Width="92" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
