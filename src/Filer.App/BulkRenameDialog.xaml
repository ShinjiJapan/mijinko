<Window x:Class="Filer.App.BulkRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Width="640" Height="560" MinWidth="520" MinHeight="420"
        ShowInTaskbar="False"
        Background="{DynamicResource Surface.Background}" Foreground="{DynamicResource Fg.Primary}"
        Title="一括リネーム">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource DialogButton}"/>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Control.Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Control}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Default}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 方式 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="方式:" Margin="0,0,12,0"/>
            <RadioButton x:Name="ModeReplace" Content="文字列置換(_R)" Checked="Mode_Changed"/>
            <RadioButton x:Name="ModeRegex" Content="正規表現(_X)" Checked="Mode_Changed"/>
            <RadioButton x:Name="ModeSequence" Content="連番(_N)" Checked="Mode_Changed"/>
        </StackPanel>

        <!-- パラメーター -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <!-- 置換 / 正規表現 -->
            <StackPanel x:Name="ReplacePanel">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="検索:"/>
                    <TextBox Grid.Column="1" x:Name="FindBox" TextChanged="Param_Changed"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="置換後:"/>
                    <TextBox Grid.Column="1" x:Name="ReplaceBox" TextChanged="Param_Changed"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="80,0,0,0">
                    <CheckBox x:Name="CaseSensitiveBox" Content="大文字小文字を区別" Click="Param_Changed"/>
                    <CheckBox x:Name="IncludeExtBox" Content="拡張子も対象" Click="Param_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- 連番 -->
            <StackPanel x:Name="SequencePanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="テンプレート:"/>
                    <TextBox Grid.Column="1" x:Name="TemplateBox" Text="*_#" TextChanged="Param_Changed"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="80,0,0,4">
                    <TextBlock Text="開始:" Margin="0,0,6,0"/>
                    <TextBox x:Name="StartBox" Text="1" Width="60" TextChanged="Param_Changed"/>
                    <TextBlock Text="増分:" Margin="16,0,6,0"/>
                    <TextBox x:Name="StepBox" Text="1" Width="60" TextChanged="Param_Changed"/>
                </StackPanel>
                <TextBlock Foreground="{DynamicResource Fg.Subtle}" FontSize="11" Margin="80,2,0,0"
                           Text="* = 元の名前(拡張子を除く)、# = 連番(### で3桁ゼロ埋め)"/>
            </StackPanel>
        </Grid>

        <!-- プレビュー -->
        <GroupBox Grid.Row="2" Header="プレビュー">
            <ListView x:Name="PreviewList" Margin="2" BorderThickness="0"
                      Background="{DynamicResource App.Background}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="元の名前" Width="240" DisplayMemberBinding="{Binding OriginalName}"/>
                        <GridViewColumn Header="新しい名前" Width="240" DisplayMemberBinding="{Binding NewName}"/>
                        <GridViewColumn Header="状態" Width="80" DisplayMemberBinding="{Binding StatusText}"/>
                    </GridView>
                </ListView.View>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="{DynamicResource Fg.Primary}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProblem}" Value="True">
                                <Setter Property="Foreground" Value="#E06C75"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUnchanged}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Fg.Subtle}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </GroupBox>

        <!-- 集計 -->
        <TextBlock Grid.Row="3" x:Name="SummaryText" Margin="2,8,2,0"
                   Foreground="{DynamicResource Fg.Secondary}"/>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton" Content="リネーム実行" Width="110" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
